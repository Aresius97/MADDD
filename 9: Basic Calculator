            if (currentInput === '') return;
            // Convert display symbol to actual operator
            let actualOp = op;
            if (op === '÷') actualOp = '/';
            if (op === '×') actualOp = '*';
            currentInput += actualOp;
            display.value = currentInput;
        }
        
